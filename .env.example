# Copy to `api/.env` when running the API from `api/`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docsage
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated browser origins, or * for allow-all (dev only)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Primary model, then comma-separated fallbacks if API returns overload / errors (see ai.google.dev model docs)
GOOGLE_AI_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_AI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash

# --- Authentication ---
# Secret used to sign JWTs (CHANGE in production!)
JWT_SECRET=CHANGE-ME-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Google OAuth (optional — leave blank to disable the Google sign-in button)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

DEBUG=True
LOG_LEVEL=INFO
