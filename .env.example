# Copy to `api/.env` when running the API from `api/`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docsage
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated browser origins, or * for allow-all (dev only)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Primary model, then comma-separated fallbacks if API returns overload / errors (see ai.google.dev model docs)
GOOGLE_AI_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_AI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash

DEBUG=True
LOG_LEVEL=INFO
